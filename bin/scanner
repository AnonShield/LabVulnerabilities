#!/usr/bin/env python3
import argparse, logging, signal, socket, sys, threading, time, yaml, json
from concurrent.futures import Future, ThreadPoolExecutor
from pathlib import Path
ROOT = Path(__file__).parent.parent
sys.path.insert(0, str(ROOT / "src"))
from vulnlab.scanner.openvas_scanner import Config, setup_logging
from vulnlab.discovery.catalog import get_source
from vulnlab.core.container import ContainerConfig
from vulnlab.core.db import ScanDB
from vulnlab.core.setup import EnvironmentSetup, SetupConfig
from vulnlab.scanner.worker import ScanWorker

class MassScanner:
    def __init__(self, db, gvm_cfg, c_cfg, workers, out, fmts, log):
        self.db, self.gvm, self.c, self.w, self.out, self.fmts, self.log = db, gvm_cfg, c_cfg, workers, out, fmts, log
        self.sd, self.host, self.local = threading.Event(), socket.gethostname(), threading.local()

    def run(self, watch=False):
        r = self.db.reset_stale(); 
        if r: self.log.info(f"Reclaimed {r} jobs")
        self._stats(); threading.Thread(target=self._prog, daemon=True).start()
        signal.signal(signal.SIGINT, lambda *_: self.sd.set()); signal.signal(signal.SIGTERM, lambda *_: self.sd.set())
        with ThreadPoolExecutor(self.w) as pool:
            active = {}
            while not self.sd.is_set():
                while len(active) < self.w and not self.sd.is_set():
                    job = self.db.claim(f"{self.host}-{threading.get_ident()}")
                    if not job: break
                    active[pool.submit(self._work, job)] = job["image"]
                done = [f for f in active if f.done()]
                for f in done: self._done(f, active.pop(f))
                if not active and self.db.stats()["pending"] == 0:
                    if watch: time.sleep(10); continue
                    break
                time.sleep(2)
        self.sd.set(); self._stats()

    def _work(self, job):
        if not hasattr(self.local, "w"): self.local.w = ScanWorker(f"{self.host}-{threading.get_ident()}", self.gvm, self.c, self.db, self.out, self.fmts, self.sd, self.log)
        return self.local.w.run(job)

    def _done(self, f, img):
        try:
            r = f.result(); s = r.get("status")
            if s == "done": self.db.done(img, r); self.log.info(f"[DONE] {img} | {r.get('vuln_total')} vulns")
            elif s == "skipped": self.db.skip(img, r.get("error")); self.log.debug(f"[SKIP] {img}")
            else: self.db.fail(img, r.get("error")); self.log.warning(f"[FAIL] {img}")
        except Exception as e: self.db.fail(img, str(e)); self.log.error(f"[ERR] {img}: {e}")

    def _stats(self):
        s = self.db.stats(); total = s["total"] or 1; pct = s["done"]/total*100
        self.log.info(f"Progress: {s['done']}/{s['total']} ({pct:.1f}%) | R:{s['running']} F:{s['failed']} S:{s['skipped']} P:{s['pending']}")
        try: (Path(self.out)/"scan_status.json").write_text(json.dumps({"at":time.ctime(), "pct":round(pct,2), **s, "machine":self.host}, indent=2))
        except: pass

    def _prog(self):
        while not self.sd.wait(30): self._stats()

def main():
    p = argparse.ArgumentParser()
    p.add_argument("--source", default="file"); p.add_argument("--file", default=str(ROOT/"data/images_all.csv"))
    p.add_argument("--workers", type=int, default=40); p.add_argument("--db", default=str(ROOT/"data/mass_scan.db"))
    p.add_argument("--output", default=str(ROOT/"data/reports")); p.add_argument("--host", default="127.0.0.1")
    p.add_argument("--port", type=int, default=9390); p.add_argument("--user", default="admin"); p.add_argument("--pw", default="admin")
    p.add_argument("-c", "--config", default=str(ROOT/"config/scanner.yaml")); p.add_argument("--seed", action="store_true")
    p.add_argument("--force", action="store_true"); p.add_argument("-v", "--verbose", action="store_true")
    p.add_argument("--watch", action="store_true", help="Watch for new images in source file")
    p.add_argument("--wait-only", action="store_true", help="Only wait for GVM and exit")
    args = p.parse_args()
    log = setup_logging(args.verbose); raw = yaml.safe_load(open(args.config).read()) if Path(args.config).exists() else {}
    db = ScanDB(args.db)
    if args.force:
        import sqlite3; c = sqlite3.connect(args.db); c.execute("UPDATE jobs SET status='pending' WHERE status IN ('failed', 'skipped')"); c.commit(); c.close()
    
    g_cfg = Config(host=args.host, port=args.port, username=args.user, password=args.pw, **{k:v for k,v in raw.items() if k in ["scan_config_name","port_list_name","scanner_name","report_formats","cleanup_after_scan","poll_interval"]})
    c_raw = raw.get("container",{})
    c_cfg = ContainerConfig(**{k:v for k,v in c_raw.items() if k in ["network","startup_wait","health_timeout","pull_retries","pull_retry_delay","max_image_size_mb","remove_image_after","prune_every","dockerhub_username","dockerhub_password"]})
    o_raw = raw.get("openvas",{})
    s_cfg = SetupConfig(network=c_raw.get("network","trabalho_vulnnet"), network_subnet=c_raw.get("network_subnet","172.30.0.0/16"), openvas_image=o_raw.get("image","immauss/openvas:latest"), container_name=o_raw.get("container_name","openvas_massscan"), gvm_password=args.pw, gvm_port=args.port, startup_timeout=o_raw.get("startup_timeout",3600))
    Path(args.output).mkdir(parents=True, exist_ok=True)
    EnvironmentSetup(s_cfg, log).run()
    if args.wait_only: return

    def _seed():
        if args.seed or args.watch:
            cfg = {**raw.get("catalog",{}), "source":args.source, "file":args.file}
            db.seed(get_source(cfg).iter_images())
    _seed()
    if args.watch:
        def _watch_seed():
            while True: time.sleep(60); _seed()
        threading.Thread(target=_watch_seed, daemon=True).start()

    MassScanner(db, g_cfg, c_cfg, args.workers, args.output, g_cfg.report_formats, log).run(watch=args.watch)

if __name__ == "__main__": main()
