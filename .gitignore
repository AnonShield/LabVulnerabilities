# =============================================================================
# VulnLab - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Arquivos de Ambiente e Credenciais (IMPORTANTE!)
# -----------------------------------------------------------------------------
.env
.env.local
*.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
venv/
*venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Logs e Estado
# -----------------------------------------------------------------------------
logs/
*.log
scanner/logs/
scanner_state.json
scanner/scanner_state.json

# -----------------------------------------------------------------------------
# Relatórios e Saídas Geradas
# -----------------------------------------------------------------------------
scanner/reports/
targets.txt
targets_full.txt
inventory_full.csv
relatorio_host.pdf

# -----------------------------------------------------------------------------
# Arquivos Temporários e de Build
# -----------------------------------------------------------------------------
build/
dist/
*.tmp
*.bak
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDE e Editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.claude/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# -----------------------------------------------------------------------------
# Arquivos Locais de Desenvolvimento
# -----------------------------------------------------------------------------
a.sh
run_containers.sh
failed_containers.csv

# -----------------------------------------------------------------------------
# Sistema Operacional
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
