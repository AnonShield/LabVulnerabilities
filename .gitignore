# =============================================================================
# VulnLab - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Arquivos de Ambiente e Credenciais (IMPORTANTE!)
# -----------------------------------------------------------------------------
.env
.env.local
*.env

# Configuração local com credenciais — use config/scanner.yaml.example como base
config/scanner.yaml

# Banco de dados e estado local
data/mass_scan.db
data/.dfs_state.json
data/.crawl_state*.json
data/images_all.csv
data/images*.csv
data/images*.jsonl
data/discovery.csv
data/discovery.jsonl
data/RESULTS.md

# Relatórios gerados
data/reports/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
venv/
*venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Logs e Estado
# -----------------------------------------------------------------------------
logs/
*.log
scanner/logs/
scanner_state.json
scanner/scanner_state.json

# -----------------------------------------------------------------------------
# Relatórios e Saídas Geradas
# -----------------------------------------------------------------------------
scanner/reports/
targets.txt
targets_full.txt
inventory_full.csv
relatorio_host.pdf

# -----------------------------------------------------------------------------
# Arquivos Temporários e de Build
# -----------------------------------------------------------------------------
build/
dist/
*.tmp
*.bak
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDE e Editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.claude/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# -----------------------------------------------------------------------------
# Arquivos Locais de Desenvolvimento
