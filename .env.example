# =============================================================================
# VulnLab - Configuração de Ambiente
#
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# O arquivo .env NÃO deve ser versionado (está no .gitignore).
#
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENCIAIS DOS BANCOS DE DADOS
# -----------------------------------------------------------------------------
# IMPORTANTE: Em ambiente de produção, use senhas fortes e únicas!

# MySQL / MariaDB
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=testdb

# PostgreSQL
POSTGRES_PASSWORD=postgres
POSTGRES_DB=testdb

# -----------------------------------------------------------------------------
# CREDENCIAIS DE SERVIÇOS
# -----------------------------------------------------------------------------

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# LDAP
LDAP_ORGANISATION=VulnLab
LDAP_DOMAIN=vulnlab.local
LDAP_ADMIN_PASSWORD=admin

# Vault
VAULT_DEV_ROOT_TOKEN_ID=myroot

# -----------------------------------------------------------------------------
# CONFIGURAÇÃO DO SCANNER OPENVAS
# -----------------------------------------------------------------------------

# Conexão GVM
GVM_HOST=127.0.0.1
GVM_PORT=9390
GVM_USERNAME=admin
GVM_PASSWORD=admin

# -----------------------------------------------------------------------------
# CONFIGURAÇÃO DE REDE
# -----------------------------------------------------------------------------

# Subnet do laboratório (padrão: 172.30.0.0/15)
VULNLAB_SUBNET=172.30.0.0/15

# -----------------------------------------------------------------------------
# OPÇÕES DE DEBUG
# -----------------------------------------------------------------------------

# Ativar modo debug (1 = ativado, 0 = desativado)
DEBUG=0

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
